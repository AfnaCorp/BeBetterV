rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isOwner(uid) {
      return request.auth != null && request.auth.uid == uid;
    }

    // Index d'unicité des usernames (id du doc = username). La réservation se fait
    // dans une transaction côté client : lecture d'existence + création si libre.
    match /usernames/{username} {
      // Lecture (existence) nécessaire à la transaction de réservation.
      allow get: if request.auth != null;
      // Seul le propriétaire réserve, et uniquement un mapping vers SON uid.
      // `create` échoue si le doc existe déjà → unicité garantie au niveau base.
      allow create: if request.auth != null
                    && request.resource.data.uid == request.auth.uid;
      // Réservation immuable depuis le client (pas de vol/écrasement d'username).
      allow update, delete: if false;
    }

    match /users/{userId} {
      allow read, write: if isOwner(userId);

      match /weights/{id}   { allow read, write: if isOwner(userId); }
      match /sleep/{id}     { allow read, write: if isOwner(userId); }
      match /meals/{id}     { allow read, write: if isOwner(userId); }
      match /sessions/{id}  { allow read, write: if isOwner(userId); }
      match /dayLogs/{id}   { allow read, write: if isOwner(userId); }
      match /facts/{id}     { allow read, write: if isOwner(userId); }
      match /wiki/{id}      { allow read, write: if isOwner(userId); }
      match /messages/{id}  { allow read, write: if isOwner(userId); }
      match /programs/{id}  { allow read, write: if isOwner(userId); }
    }
  }
}
